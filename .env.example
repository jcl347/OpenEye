# Copy this file to .env and fill in the real values. .env is gitignored.
# These vars are read by .mcp.json (${VAR} interpolation) and by scripts/scan.ps1.

# --- Anthropic (only needed if you authenticate Claude Code via API key) ---
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Facebook Marketplace MCP (fisheyes/mcp-facebook-market-place) ---
# Local checkout of the MCP repo (used by scripts/start-fb-mcp.ps1).
FB_MCP_DIR=C:\path\to\mcp-facebook-market-place
# Where the locally running MCP server is reachable (default shown).
FB_MCP_URL=http://127.0.0.1:8000/mcp
# OPTIONAL: persistent logged-in session. Point this at a folder to store FB cookies, then
# run a one-time login:  uv run python scraper.py --login   (in the FB MCP dir, with this set).
# Logged-in scans see deeper results and hit fewer walls — but logged-in scraping more
# clearly violates Facebook's ToS and risks the account. Leave unset for logged-out scraping.
# FB_PROFILE_DIR=C:\path\to\.fb-profile
# Facebook NUMERIC area ID that anchors the search. NOT a city name or lat/long.
# The MCP default (108339199186201) is the UK — you MUST override it.
# See README > "Finding your Facebook location_id" to get the Seattle-area value.
FB_LOCATION_ID=REPLACE_WITH_SEATTLE_AREA_LOCATION_ID

# --- Resale comps: local eBay sold-comps MCP (no token, no per-call cost) ---
# A local Playwright MCP in mcp/ebay-sold-comps, launched on demand via .mcp.json.
# Run `uv sync` in that folder once. Only set EBAY_MCP_DIR if you move it elsewhere.
# EBAY_MCP_DIR=C:\path\to\ebay-sold-comps
