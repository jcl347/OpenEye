+def login():
+    """OpenEye: one-time interactive Facebook login into a persistent profile.
+
+    Opens a visible Chromium using FB_PROFILE_DIR. Log in once; cookies persist there,
+    so subsequent (headless) scrapes reuse the session — fewer walls, deeper results.
+    """
+    profile = os.environ.get('FB_PROFILE_DIR')
+    if not profile:
+        print("Set FB_PROFILE_DIR to a folder path first (it will store the saved session).")
+        sys.exit(1)
+
+    with sync_playwright() as p:
+        context = p.chromium.launch_persistent_context(
+            profile, headless=False, viewport={'width': 1280, 'height': 900})
+        page = context.pages[0] if context.pages else context.new_page()
+        page.goto("https://www.facebook.com/login", wait_until='domcontentloaded')
+        print(f"\nA browser opened. Log in to Facebook, then come back here and press Enter.")
+        print(f"(Session will be saved to: {profile})")
+        try:
+            input()
+        except EOFError:
+            page.wait_for_timeout(120000)
+        context.close()
+    print("Login session saved. Set FB_PROFILE_DIR in your .env and future scans reuse it.")
+
